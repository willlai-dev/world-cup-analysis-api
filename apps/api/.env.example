NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
API_GLOBAL_PREFIX=api
FRONTEND_URL=http://localhost:3001

# Reuse your existing local Postgres. If the password contains URL-reserved
# characters and Prisma fails to parse, URL-encode them (e.g. ! -> %21).
DATABASE_URL=postgresql://user:password@localhost:5432/footy_predict_dev

JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=7d
COOKIE_SECRET=replace-with-long-random-secret
CRON_SECRET=replace-with-long-random-secret

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123456
SEED_ADMIN_DISPLAY_NAME=Initial Admin
SEED_PREMIUM_EMAIL=premium@example.com
SEED_PREMIUM_PASSWORD=premium123456
SEED_USER_EMAIL=user@example.com
SEED_USER_PASSWORD=user123456

NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL_SUPER=nvidia/nemotron-3-super-120b-a12b
NVIDIA_MODEL_ULTRA=nvidia/nemotron-3-ultra-550b-a55b

DASHSCOPE_API_KEY=
QWEN_OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1
QWEN_MODEL_PLUS=qwen3.7-plus
QWEN_MODEL_FLASH=qwen3.6-flash
QWEN_MODEL_FLASH_FALLBACK=qwen3.5-flash

FOOTBALL_DATA_API_KEY=
GUARDIAN_API_KEY=
NEWS_API_KEY=

# Phase 1: keep true so AI endpoints are testable without external keys.
AI_MOCK_MODE=true
